{
  "name": "myfinance-backup-runner",
  "version": "1.0.0",
  "description": "HTTP sidecar that orchestrates pg_dump-based backups for MyFinanceView",
  "main": "server.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "node server.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "pino": "^9.1.0",
    "pino-http": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "license": "UNLICENSED",
  "private": true
}
