# Force LF for shell scripts and Maven wrapper so they run on Linux CI
# even when checked in from Windows (core.autocrlf=true).
mvnw                text eol=lf
*.sh                text eol=lf
.mvn/wrapper/**     text eol=lf

# Force CRLF for Windows-only files
mvnw.cmd            text eol=crlf
*.bat               text eol=crlf

# Treat binary files as binary
*.jar               binary
*.png               binary
*.jpg               binary
*.webp              binary
