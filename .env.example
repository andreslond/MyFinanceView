# MyFinanceView — environment variable contract.
# Copy to .env.local (gitignored) and fill in real values.
# See docs/development-guide.md §2 for the canonical list.

# ---------------------------------------------------------------------------
# Supabase project (akkoqdjmmozyqdfjkabg)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://akkoqdjmmozyqdfjkabg.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Spring Security validates Bearer JWTs via the asymmetric JWKS public endpoint
# (ES256). The legacy symmetric SUPABASE_JWT_SECRET is no longer used —
# Supabase Auth migrated to ES256 / P-256 (verified 2026-06-02).
SUPABASE_JWT_JWKS_URI=https://akkoqdjmmozyqdfjkabg.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://akkoqdjmmozyqdfjkabg.supabase.co/auth/v1
# Direct JDBC URL for the backend pool (jOOQ + HikariCP). Use the session
# pooler in us-west-2 for IPv4 compatibility.
SUPABASE_DB_URL=jdbc:postgresql://aws-0-us-west-2.pooler.supabase.com:5432/postgres
# CSV of additional CORS-allowed origins for the production Vercel domain or
# any custom domain. https://*.vercel.app preview pattern is always allowed;
# http://localhost:5173 is auto-allowed only in `local` and `test` profiles.
APP_CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Direct Postgres connection (jOOQ codegen + Testcontainers seed checks).
# For local development use the Docker Compose service on LOCAL_DB_PORT.
# ---------------------------------------------------------------------------
DB_HOST=db.akkoqdjmmozyqdfjkabg.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_SCHEMA=myfinance
DB_USER=
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Internal webhook (POST /api/v1/feedback/transaction from n8n).
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Local infrastructure
# ---------------------------------------------------------------------------
# Host port for the Docker Compose Postgres (avoid colliding with a local 5432).
LOCAL_DB_PORT=5433

# ===========================================================================
# Backup pipeline (consumed by n8n + the `myfinance-backup-runner` sidecar
# container on the VPS). NOT read by the Spring Boot app.
# These live in n8n Credentials in production; this file is documentation only.
# See archive/openspec-legacy/changes/archive/2026-06-08-supabase-backup-policy/design.md.
# ===========================================================================

# --- Supabase Session Pooler target (NOT the same as DB_HOST/DB_USER above) -
# The backup script connects through the IPv4-compatible session pooler, not
# the direct endpoint. Confirm the region in Supabase Dashboard → Connect →
# Session pooler; MyFinanceView lives in us-west-2 (verified 2026-05-13).
BACKUP_DB_HOST=aws-0-us-west-2.pooler.supabase.com
BACKUP_DB_PORT=5432
BACKUP_DB_NAME=postgres
BACKUP_DB_USER=postgres.akkoqdjmmozyqdfjkabg
# Same Postgres role password as DB_PASSWORD — but kept in n8n credentials only
# so the sidecar can be operated independently of the Spring Boot app secrets.
BACKUP_DB_PASSWORD=

# --- Cloudflare R2 -----------------------------------------------------------
# Account ID is the 32-char hex in your Cloudflare dashboard URL.
BACKUP_R2_ACCOUNT_ID=
BACKUP_R2_BUCKET=my-finance-view-backups
BACKUP_R2_REGION=auto
# Generate at Cloudflare → R2 → Manage R2 API tokens, scoped to the bucket only.
BACKUP_R2_ACCESS_KEY_ID=
BACKUP_R2_SECRET_ACCESS_KEY=

# --- age encryption ---------------------------------------------------------
# The PRIMARY recipient public key lives at scripts/backup/recipients/primary.txt
# and is baked into the runner image at build time — no env var for it.
# v3 (Gate C cut B1): single-recipient encryption. The dual-paper recovery key
# was removed because the threat model excludes the local-forensic adversary.
# PRIMARY private key (identity) — NEVER write to disk on the VPS. Read into a
# bash variable from the runner's stdin pipe, written briefly to a tmpfs file
# (mode 0600, trap-deleted) for `age -d -i`. Lives in n8n credentials only.
# Operator copies: Windows PC at %USERPROFILE%\.config\myfinance-backup\, plus
# sealed paper at off-site location A.
MYFINANCE_BACKUP_AGE_IDENTITY=

# --- Alerting (v1, operator decision 2026-06-01) ----------------------------
# Two-channel alerting: ntfy.sh push + Resend transactional email.
# Uptime Kuma in-cluster dead-man-switch and healthchecks.io off-VPS pinger are
# BOTH deferred in v1 — the operator's external uptime monitor on
# n8n.datachefnow.com covers the host-down case. See design.md Decision 7.
#
# Unguessable slug — treat as a secret. Recipients subscribe at ntfy.sh/<topic>.
MYFINANCE_BACKUP_NTFY_TOPIC=
# Resend API key (https://resend.com/api-keys) scoped to "Sending access" only,
# on the verified datachefnow.com domain (Route 53 / us-east-1).
MYFINANCE_BACKUP_RESEND_API_KEY=
# Sender address — must be on a verified Resend domain. Production hygiene:
# the operator wants infrastructure email to come from the system domain, not
# from a personal Gmail. Default for MyFinanceView is alerts@datachefnow.com.
MYFINANCE_BACKUP_ALERT_FROM=alerts@datachefnow.com
# Recipient inbox — where alert emails land (the operator's mailbox).
MYFINANCE_BACKUP_ALERT_TO=
# v1 cuts (operator decision 2026-06-01) — reinstate by re-adding the env vars
# here AND wiring the corresponding workflow / worker step:
#   * MYFINANCE_BACKUP_GMAIL_APP_PASSWORD: replaced by Resend.
#   * MYFINANCE_BACKUP_KUMA_PUSH_URL: Kuma Push Monitor deferred.
#   * MYFINANCE_BACKUP_HEALTHCHECKS_URL: off-VPS pinger deferred.

# --- Pre-op trigger ---------------------------------------------------------
# v3 (Gate C cut M3): the public pre-op webhook + Traefik IP allowlist were
# removed. PreOp now triggers from the n8n UI manually (Execute Workflow on the
# MyFinanceBackup-PreOp workflow with the `reason` field edited in the Set node).
# No MYFINANCE_PREOP_WEBHOOK_SECRET required.

# --- Sidecar HTTP API -------------------------------------------------------
# Internal-network URL the n8n container uses to call the runner sidecar.
# Default form is service-name on the shared Docker network (no TLS needed).
MYFINANCE_BACKUP_RUNNER_URL=http://myfinance-backup-runner:8080
# Shared header secret between n8n → sidecar, separate from the pre-op webhook.
MYFINANCE_BACKUP_RUNNER_SECRET=
