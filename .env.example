# MyFinanceView — environment variable contract.
# Copy to .env.local (gitignored) and fill in real values.
# See docs/development-guide.md §2 for the canonical list.

# ---------------------------------------------------------------------------
# Supabase project (akkoqdjmmozyqdfjkabg)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://akkoqdjmmozyqdfjkabg.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Used by Spring Security to validate Bearer JWTs issued by Supabase Auth.
SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# Direct Postgres connection (jOOQ codegen + Testcontainers seed checks).
# For local development use the Docker Compose service on LOCAL_DB_PORT.
# ---------------------------------------------------------------------------
DB_HOST=db.akkoqdjmmozyqdfjkabg.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_SCHEMA=myfinance
DB_USER=
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Internal webhook (POST /api/v1/feedback/transaction from n8n).
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Local infrastructure
# ---------------------------------------------------------------------------
# Host port for the Docker Compose Postgres (avoid colliding with a local 5432).
LOCAL_DB_PORT=5433
