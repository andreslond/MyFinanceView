# MyFinanceView — environment variable contract.
# Copy to .env.local (gitignored) and fill in real values.
# See docs/development-guide.md §2 for the canonical list.

# ---------------------------------------------------------------------------
# Supabase project (akkoqdjmmozyqdfjkabg)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://akkoqdjmmozyqdfjkabg.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Used by Spring Security to validate Bearer JWTs issued by Supabase Auth.
SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# Direct Postgres connection (jOOQ codegen + Testcontainers seed checks).
# For local development use the Docker Compose service on LOCAL_DB_PORT.
# ---------------------------------------------------------------------------
DB_HOST=db.akkoqdjmmozyqdfjkabg.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_SCHEMA=myfinance
DB_USER=
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Internal webhook (POST /api/v1/feedback/transaction from n8n).
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Local infrastructure
# ---------------------------------------------------------------------------
# Host port for the Docker Compose Postgres (avoid colliding with a local 5432).
LOCAL_DB_PORT=5433

# ---------------------------------------------------------------------------
# Backup pipeline (scripts/backup/) — copy this section into
# scripts/backup/.env.local on the VPS and fill in real values.
# See scripts/backup/README.md for the full operator runbook.
# ---------------------------------------------------------------------------

# Supabase Session Pooler connection (used by pg_dump; NOT the direct endpoint)
# Host format: aws-0-<region>.pooler.supabase.com (check Supabase Dashboard → Connect)
BACKUP_DB_HOST=
BACKUP_DB_PORT=5432
BACKUP_DB_NAME=postgres
BACKUP_DB_USER=postgres.akkoqdjmmozyqdfjkabg
BACKUP_DB_PASSWORD=

# Cloudflare R2 credentials (Object Read & Write on my-finance-view-backups)
BACKUP_R2_ACCESS_KEY_ID=
BACKUP_R2_SECRET_ACCESS_KEY=
BACKUP_R2_ACCOUNT_ID=
BACKUP_R2_BUCKET=my-finance-view-backups

# age encryption — identity for restore-verify (primary private key, NOT recovery)
# The primary private key content is stored here only in the n8n credential store
# (never in this file on disk). Placeholder shows expected format.
MYFINANCE_BACKUP_AGE_IDENTITY=

# ntfy.sh push notifications
MYFINANCE_BACKUP_NTFY_TOPIC=

# Gmail SMTP alerting (App Password — not the account password)
MYFINANCE_BACKUP_GMAIL_APP_PASSWORD=

# Pre-op webhook shared secret (external caller → n8n webhook)
MYFINANCE_PREOP_WEBHOOK_SECRET=

# Runner sidecar URL (used by n8n HTTP Request nodes)
MYFINANCE_BACKUP_RUNNER_URL=http://myfinance-backup-runner:8080

# Runner shared secret (n8n → sidecar X-Runner-Secret header)
MYFINANCE_BACKUP_RUNNER_SECRET=

# Uptime Kuma Push Monitor URL (dead-man-switch, pings on backup success)
MYFINANCE_BACKUP_KUMA_PUSH_URL=

# healthchecks.io check URL (off-VPS dead-man-switch, pings on backup success)
# Obtain from healthchecks.io dashboard after creating the myfinance-backup-daily check.
MYFINANCE_BACKUP_HEALTHCHECKS_URL=
