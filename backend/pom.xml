<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.5</version>
        <relativePath/>
    </parent>

    <groupId>com.myfinanceview</groupId>
    <artifactId>myfinanceview</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>myfinanceview</name>
    <description>Personal finance backend for Bogotá-based user — Spring Boot + jOOQ.</description>

    <properties>
        <java.version>25</java.version>
        <maven.compiler.release>25</maven.compiler.release>
        <jooq.version>3.19.15</jooq.version>
        <postgresql.version>42.7.4</postgresql.version>
        <testcontainers.version>1.20.4</testcontainers.version>
        <rest-assured.version>5.5.0</rest-assured.version>
        <!-- Pinned explicitly because nimbus-jose-jwt is pulled transitively by
             spring-security-oauth2-jose; we depend on JWSObject/ECDSASigner directly
             in TestJwtFactory and want a deterministic version. -->
        <nimbus-jose-jwt.version>9.40</nimbus-jose-jwt.version>
        <!-- WireMock 3.x is the supported line for JDK17+/Jetty12. Standalone is
             pre-shaded so it does not collide with the Spring test context's Jetty. -->
        <wiremock.version>3.9.2</wiremock.version>
    </properties>

    <dependencies>
        <!-- Web + Actuator + Validation -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- Security: OAuth2 Resource Server (validates JWTs against Supabase JWKS).
             See backend-mvp-readonly design.md D1. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-oauth2-resource-server</artifactId>
        </dependency>
        <!-- TestJwtFactory uses JWSObject + ECDSASigner directly; declare explicitly
             so the version is reproducible across spring-boot upgrades. -->
        <dependency>
            <groupId>com.nimbusds</groupId>
            <artifactId>nimbus-jose-jwt</artifactId>
            <version>${nimbus-jose-jwt.version}</version>
        </dependency>

        <!-- Data access: jOOQ + Postgres JDBC.
             We override the Spring-Boot-managed jOOQ version to 3.19+ to match docs/backend-standards.md §1.
             starter-jooq pulls spring-jdbc + spring-tx (needed for @Transactional in TransactionService)
             and the jOOQ auto-configuration that wires DSLContext from the Hikari DataSource. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-jooq</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jooq</groupId>
            <artifactId>jooq</artifactId>
            <version>${jooq.version}</version>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>${postgresql.version}</version>
            <scope>runtime</scope>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>postgresql</artifactId>
            <version>${testcontainers.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${testcontainers.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.rest-assured</groupId>
            <artifactId>rest-assured</artifactId>
            <version>${rest-assured.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- WireMock standalone (shaded) for the JWKS endpoint used by SecurityIntegrationTest.
             Standalone variant prevents Jetty/Servlet version conflicts with the Spring Boot
             test context. See backend-mvp-readonly tasks.md §3.5. -->
        <dependency>
            <groupId>org.wiremock</groupId>
            <artifactId>wiremock-standalone</artifactId>
            <version>${wiremock.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <release>25</release>
                    <!-- No preview flags: every Java 25 feature we need (Records, pattern matching for switch,
                         Virtual Threads, sealed types) is stabilised. See archive/openspec-legacy/changes/archive/2026-05-13-backend-scaffolding/design.md D1. -->
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>

            <!-- Surefire: enable Byte Buddy experimental support so Mockito can instrument
                 classes on Java 25 (Byte Buddy 1.15 officially supports up to Java 24). Used
                 only by tests that need @MockBean (e.g. TransactionServiceAtomicityTest, where
                 we intercept MerchantUpserter.applyFeedback to force a rollback path). -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>-Dnet.bytebuddy.experimental=true -XX:+EnableDynamicAgentLoading</argLine>
                </configuration>
            </plugin>

            <!-- jOOQ codegen plugin: declared but NOT bound to a default phase.
                 Generated sources live under target/generated-sources/jooq/ and are gitignored.
                 Activate explicitly with: mvn -P codegen generate-sources -->
            <plugin>
                <groupId>org.jooq</groupId>
                <artifactId>jooq-codegen-maven</artifactId>
                <version>${jooq.version}</version>
                <executions>
                    <execution>
                        <id>codegen</id>
                        <phase>none</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- Add target/generated-sources/jooq/ as a compile source root unconditionally.
                 Codegen writes there (gitignored) under the `codegen` profile; once generated,
                 these classes must be on the compile classpath for every subsequent build
                 (compile, test, package) without re-running codegen. The directory may be empty
                 when codegen has not been run yet — `mvn compile` will then fail loudly with
                 "package com.myfinanceview.jooq.generated does not exist", which is the right
                 signal: re-run `mvn -P codegen generate-sources`. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>add-jooq-generated-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${project.build.directory}/generated-sources/jooq</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- PIT (pitest) mutation testing — harness Uncle Bob (docs/uncle-bob/mutation-testing.md).
                 Reemplaza al stryker.conf.json del harness TS de referencia. Acotado al dominio puro
                 (com.myfinanceview.domain.*); el agente mutation_tester lo invoca con override de
                 -DtargetClasses/-DtargetTests por feature. NO bound a ninguna fase: se corre a mano con
                 `mvnd org.pitest:pitest-maven:mutationCoverage`. Reporte en target/pit-reports/.
                 Nota: requiere el modulo compilado (codegen jOOQ corrido). Verificar versiones contra
                 el JDK 25 la primera vez que se ejecute. -->
            <plugin>
                <groupId>org.pitest</groupId>
                <artifactId>pitest-maven</artifactId>
                <!-- 1.25.x bundles ASM 9.8+, which reads class file major version 69 (JDK 25).
                     Earlier PIT (1.17.4) shipped ASM 9.7.1 (max JDK 24) and failed on JDK-25
                     bytecode with "Unsupported class file major version 69". -->
                <version>1.25.5</version>
                <dependencies>
                    <dependency>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-junit5-plugin</artifactId>
                        <version>1.2.3</version>
                    </dependency>
                </dependencies>
                <configuration>
                    <targetClasses>
                        <param>com.myfinanceview.domain.*</param>
                    </targetClasses>
                    <targetTests>
                        <param>com.myfinanceview.domain.*</param>
                    </targetTests>
                    <mutators>
                        <mutator>STRONGER</mutator>
                    </mutators>
                    <outputFormats>
                        <param>HTML</param>
                        <param>XML</param>
                    </outputFormats>
                    <timestampedReports>false</timestampedReports>
                    <mutationThreshold>100</mutationThreshold>
                    <failWhenNoMutations>false</failWhenNoMutations>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <!--
                jOOQ codegen profile. Activate with:
                    mvn -P codegen generate-sources

                Prerequisite: a local Postgres reachable on jdbc:postgresql://localhost:5433/myfinance_local
                with V001..V005 already applied (docker compose -f docker/docker-compose.yml up -d).
                Connection settings can be overridden via -Dcodegen.db.url=... etc. The fallbacks
                match `docker/docker-compose.yml` (port 5433, user/db `myfinance`).

                Output: target/generated-sources/jooq/com/myfinanceview/jooq/generated/myfinance/**
                The directory is gitignored.

                Inputs covered: myfinance.{accounts,categories,transactions,merchants,banks,
                user_settings,budgets,budget_categories,exchange_rates}. The auth, public, and
                pg_* schemas are excluded.
            -->
            <id>codegen</id>
            <properties>
                <codegen.db.url>jdbc:postgresql://localhost:5433/myfinance_local</codegen.db.url>
                <codegen.db.user>myfinance</codegen.db.user>
                <codegen.db.password>localpassword</codegen.db.password>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.jooq</groupId>
                        <artifactId>jooq-codegen-maven</artifactId>
                        <version>${jooq.version}</version>
                        <executions>
                            <execution>
                                <id>codegen</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>generate</goal>
                                </goals>
                            </execution>
                        </executions>
                        <dependencies>
                            <dependency>
                                <groupId>org.postgresql</groupId>
                                <artifactId>postgresql</artifactId>
                                <version>${postgresql.version}</version>
                            </dependency>
                        </dependencies>
                        <configuration>
                            <jdbc>
                                <driver>org.postgresql.Driver</driver>
                                <url>${codegen.db.url}</url>
                                <user>${codegen.db.user}</user>
                                <password>${codegen.db.password}</password>
                            </jdbc>
                            <generator>
                                <database>
                                    <name>org.jooq.meta.postgres.PostgresDatabase</name>
                                    <inputSchema>myfinance</inputSchema>
                                    <!-- Map the auth.users FK target schema so jOOQ doesn't choke on
                                         cross-schema references; we don't include auth in generated code. -->
                                    <includes>.*</includes>
                                    <excludes></excludes>
                                </database>
                                <target>
                                    <packageName>com.myfinanceview.jooq.generated</packageName>
                                    <directory>target/generated-sources/jooq</directory>
                                </target>
                                <generate>
                                    <records>true</records>
                                    <pojos>false</pojos>
                                    <daos>false</daos>
                                    <fluentSetters>false</fluentSetters>
                                </generate>
                            </generator>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
