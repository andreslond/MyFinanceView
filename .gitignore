# Build output
target/
target/generated-sources/jooq/
*.class

# Node dependencies (runner sidecar — package-lock.json IS committed, node_modules is NOT)
node_modules/

# Local backups (operator pre-V00x snapshots)
backups/
# Maven
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.project
.classpath
.settings/

# Spring Boot
HELP.md
*.log

# Local env (any .env.* except the committed example)
.env
.env.*
!.env.example

# age identities — NEVER commit any private key file
age-identity*
**/age-identity*
*.identity
# Whitelist the PUBLIC recipient files (these MUST be tracked so the runner
# image bakes the right recipient at build time)
!scripts/backup/recipients/*.txt

# OS
.DS_Store
Thumbs.db

# Google Drive sync junk
*.tmp.driveupload
*.tmp.drivedownload
.tmp.drivedownload/

# Claude Code local state
.claude/settings.local.json
.claude/worktrees/
