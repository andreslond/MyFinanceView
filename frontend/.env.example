# Frontend env vars (Vite reads these at build time)
# Copy this file to .env.local and fill in the values from Supabase dashboard.
# .env.local is gitignored — never commit credentials.
#
# How to get these:
#   - VITE_SUPABASE_URL: Supabase dashboard → Settings → API → "Project URL"
#                       or via mcp: get_project_url(project_id=akkoqdjmmozyqdfjkabg)
#   - VITE_SUPABASE_ANON_KEY: Supabase dashboard → Settings → API → "anon public" (legacy JWT)
#                       or via mcp: get_publishable_keys(project_id=akkoqdjmmozyqdfjkabg)

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_JWT_KEY
